// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Upload {
  id         String   @id @default(cuid())
  fileName   String
  fileUrl    String   // Cloudinary secure URL
  publicId   String   // Cloudinary public_id for deletion
  mimeType   String
  fileSize   String
  status     String   @default("processing") // processing | done | failed
  uploadedAt DateTime @default(now())

  records    Record[]
}

model Record {
  id       String @id @default(cuid())
  uploadId String
  upload   Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  // Extracted operational fields
  date          String  @default("")
  shift         String  @default("")
  employeeNum   String  @default("")
  opCode        String  @default("")
  machineNum    String  @default("")
  workOrderNum  String  @default("")
  quantity      Float?
  timeTaken     Float?

  // Per-field confidence scores (0.0 – 1.0)
  confDate         Float @default(0)
  confShift        Float @default(0)
  confEmployeeNum  Float @default(0)
  confOpCode       Float @default(0)
  confMachineNum   Float @default(0)
  confWorkOrderNum Float @default(0)
  confQuantity     Float @default(0)
  confTimeTaken    Float @default(0)

  // Record lifecycle
  status      String   @default("valid") // valid | exception | reviewed
  manualNotes String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  validationErrors ValidationError[]
}

model ValidationError {
  id           String   @id @default(cuid())
  recordId     String
  record       Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)

  field        String   // which field caused the error (or "global")
  errorType    String   // MISSING_FIELD | INVALID_SHIFT | DUPLICATE_WO | INVALID_FORMAT | SUSPICIOUS_VALUE | ZERO_QUANTITY
  errorMessage String   // human-readable description
  createdAt    DateTime @default(now())
}
